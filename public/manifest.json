{
  "manifest_version": 3,
  "name": "ThunderJira",
  "version": "1.2.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",

  "browser_specific_settings": {
    "gecko": {
      "id": "thunderjira@micz.it",
      "strict_min_version": "140.0"
    }
  },

  "background": {
    "scripts": ["background/background.js"],
    "type": "module"
  },

  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": false
  },

  "message_display_action": {
    "default_title": "__MSG_menuCreateIssue__",
    "default_icon": {
      "16": "icons/icon-16px.png",
      "32": "icons/icon-32px.png",
      "64": "icons/icon.png"
    }
  },

  "permissions": [
    "messagesRead",
    "messagesModify",
    "accountsRead",
    "scripting",
    "storage",
    "menus",
    "webRequest",
    "webRequestBlocking"
  ],

  "host_permissions": [
    "https://*.atlassian.net/*"
  ],

  "optional_host_permissions": [
    "https://*/*",
    "http://*/*",
    "<all_urls>"
  ],

  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/icon-16px.png",
    "32": "icons/icon-32px.png",
    "64": "icons/icon.png"
  }
}
